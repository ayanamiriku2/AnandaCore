# Environment
POSTGRES_USER=anandacore
POSTGRES_PASSWORD=anandacore_secret
POSTGRES_DB=anandacore
POSTGRES_PORT=5432

# JWT
JWT_SECRET=change_me_in_production_must_be_at_least_32_characters_long
JWT_EXPIRY_HOURS=24
REFRESH_TOKEN_EXPIRY_DAYS=30

# S3 / MinIO
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=anandacore
S3_SECRET_KEY=anandacore_secret
S3_BUCKET=anandacore-files
S3_REGION=us-east-1
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# Backend
APP_HOST=0.0.0.0
APP_PORT=8080
RUST_LOG=info,anandacore=debug
ALLOWED_ORIGINS=http://localhost:3000

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8080
FRONTEND_PORT=3000
