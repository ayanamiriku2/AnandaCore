# ===========================================
# AnandaCore Environment Variables
# ===========================================
# Copy this file to .env for local development
# For Railway: set these in the Variables tab
# ===========================================

# Database (REQUIRED)
# Railway: use ${{Postgres.DATABASE_URL}}
DATABASE_URL=postgresql://anandacore:anandacore_secret@localhost:5432/anandacore

# JWT (REQUIRED)
JWT_SECRET=change_me_in_production_must_be_at_least_32_characters_long
JWT_EXPIRY_HOURS=24
REFRESH_TOKEN_EXPIRY_DAYS=30

# S3 / MinIO (optional - has defaults)
# Railway: use http://<minio-service>.railway.internal:9000
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=anandacore
S3_SECRET_KEY=anandacore_secret
S3_BUCKET=anandacore-files
S3_REGION=us-east-1

# Backend (optional - has defaults)
APP_HOST=0.0.0.0
APP_PORT=8080
RUST_LOG=info
ALLOWED_ORIGINS=http://localhost:3000

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8080
